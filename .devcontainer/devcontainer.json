{
    "name": "IGNISX Bot - Dev Environment",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python3",
                "python.analysis.extraPaths": ["/workspaces/MyAIBot"]
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy"
            ]
        }
    },
    "postCreateCommand": "pip3 install --upgrade pip && pip3 install --no-cache-dir -r requirements.txt",
    "postStartCommand": "pip3 install --quiet -r requirements.txt",
    "remoteUser": "vscode",
    "workspaceFolder": "/workspaces/MyAIBot"
}
