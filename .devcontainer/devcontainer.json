{
    "name": "MyAIBot - Automated Dev Environment",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python3",
                "python.analysis.extraPaths": ["/workspace"]
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },
    // يضمن هذا الأمر تثبيت المكتبات تلقائياً عند فتح البيئة لأول مرة أو إعادة تشغيلها
    // نستخدم --upgrade لضمان تحديث المكتبات إذا تغير ملف requirements.txt
    "postCreateCommand": "pip3 install --upgrade pip && pip3 install -r requirements.txt",
    "remoteUser": "vscode"
}
